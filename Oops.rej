-// paginatedNodeQuery returns a sortBy-based paginated Joern DSL query for
-// the given node type. Uses the same stable-ordering pattern as the
-// queryMethodsPaginated / queryCallsPaginated helpers in queries.go.
-func paginatedNodeQuery(nt cpg.NodeType, skip, take int) string {
-	switch nt {
-	case cpg.NodeMethod:
-		return queryMethodsPaginated(skip, take)
-	case cpg.NodeCall:
-		return queryCallsPaginated(skip, take)
-	case cpg.NodeParameter:
-		return nodeQuery(
-			fmt.Sprintf("cpg.parameter\n  .sortBy(_.id)\n  .drop(%d)\n  .take(%d)", skip, take),
-			"p", "p.name", "p.location.filename",
-		)
-	case cpg.NodeIdentifier:
-		return nodeQuery(
-			fmt.Sprintf("cpg.identifier\n  .sortBy(_.id)\n  .drop(%d)\n  .take(%d)", skip, take),
-			"i", "i.name", "i.location.filename",
-		)
-	case cpg.NodeLiteral:
-		return nodeQuery(
-			fmt.Sprintf("cpg.literal\n  .sortBy(_.id)\n  .drop(%d)\n  .take(%d)", skip, take),
-			"l", "l.code", "l.location.filename",
-		)
-	default:
-		return nodeQuery(
-			fmt.Sprintf("cpg.graph.nodes\n  .filter(_._label == %q)\n  .sortBy(_.id)\n  .drop(%d)\n  .take(%d)", string(nt), skip, take),
