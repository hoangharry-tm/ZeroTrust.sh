flowchart LR
    Input[/"Codebase Directory"/]

    subgraph INGEST["Ingestion Layer"]
        direction TB
        DI["<b>Differential Indexer (DI)</b><br>• Tracks file changes via SQLite AST hashes<br>• Expands change blast-radius for context<br>• Segments active modules & neighbors"]
        
        MIV["<b>Model Integrity Verifier (MIV)</b><br>• Verifies signed AI registries via cosign<br>• Falls back gracefully if verification fails<br>• Passes cryptographic validation status down"]
    end

    subgraph SHARED_ENGINE["Shared Graph Engine"]
        Joern["<b>Joern CPG Compiler</b><br>• Asynchronously builds universal CPG<br>• Streams cross-file taint & call graphs"]
    end

    subgraph PA["Path A — Orchestration Hub"]
        PA_OH["<b>Tool Orchestrator</b><br>• Detects tech stack & languages<br>• Dispatches match-fit OSS scanners<br>  (OpenGrep, Gitleaks, linters)"]
        PA_LV["<b>LLM Verifier</b><br>• Filters out orchestrator noise<br>  via local LLM constraint checks"]
        
        PA_OH --> PA_LV
    end

    subgraph PB["Path B — Semantic Analysis Funnel"]
        direction TB
        subgraph T1["Tier 1 — Surface Selection"]
            PB_SS["<b>Surface Selector</b><br>• Consumes CPG data to rank risk profiles<br>• Eliminates ~95% of safe code surfaces"]
        end
        subgraph T2["Tier 2 — Classifier Chain"]
            PB_CC["<b>Classifier Chain (CodeT5+)</b><br>• Evaluates remaining targets on CPU<br>• Generates structural function summaries"]
        end
        subgraph T3["Tier 3 — LLM Reasoning"]
            PB_TBC["<b>Token Budget Controller</b><br>• Tracks resource consumption metrics<br>• Warns devs when approaching/over budget<br>• Never blocks execution or drops surfaces"]
            
            PB_LR["<b>LLM Reasoner</b><br>• Bounded ReAct loops over high-risk surfaces<br>• Tracks cross-cutting structural flaws"]
            
            PB_TBC --> PB_LR
        end
        
        PB_SS --> PB_CC
        PB_CC -->|"uncertain cases"| PB_TBC
    end

    %% Execution Core Flow (Left to Right)
    Input --> DI
    Input --> MIV
    
    %% Concurrent Fork from DI
    DI --> PA_OH
    DI --> Joern
    DI --> PB_SS
    
    %% Pass Ingestion Metadata & Signatures (Non-Blocking)
    MIV -.->|"streams signature status"| PA_LV
    MIV -.->|"streams signature status"| PB_TBC

    %% Graph Streams (Asynchronous References)
    Joern -.->|"inter-procedural taint"| PA_OH
    Joern -.->|"seeds reachability primitives"| PB_SS

    %% Output Fan-in to Dedup
    PA_LV --> Dedup
    PB_CC -->|"high-confidence"| Dedup
    PB_LR --> Dedup

    Dedup["<b>Dedup & Report Generator</b><br>• Cascaded finding deduplication & SSVC alignment<br>• Combines engine findings with budget/MIV alerts"]

    subgraph PoE["Proof-of-Exploit (PoE) Layer"]
        PoE_Engine["<b>Automated Red-Team Agent</b><br>• Filters findings for confirmable flaw classes<br>• Executes sandboxed exploit simulations in gVisor<br>• Generates verified impact traces to eliminate false positives"]
    end

    %% Routing Through Exploit Validation Layer
    Dedup -->|"BLOCK / HIGH targets"| PoE_Engine
    Dedup --> FinalReport
    PoE_Engine -->|"attaches exploit verification status"| FinalReport

    FinalReport[/"<b>Interactive HTML Report</b><br>Includes validated patch suggestions & exploit evidence"/]

    %% Color Adjustments
    style INGEST fill:#eef2ff,stroke:#c7d2fe
    style SHARED_ENGINE fill:#faf5ff,stroke:#e9d5ff
    style PA fill:#f0f9ff,stroke:#bae6fd
    style PB fill:#ecfdf5,stroke:#a7f3d0
    style T1 fill:#fef9c3,stroke:#eab308
    style T2 fill:#ffedd5,stroke:#f97316
    style T3 fill:#fee2e2,stroke:#ef4444
    style PoE fill:#fee2e2,stroke:#ef4444
