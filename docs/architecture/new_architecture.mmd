flowchart LR
    Input[/"Codebase Directory"/]

    subgraph INGEST["Ingestion Layer"]
        direction TB
        DI["<b>Differential Indexer (DI)</b><br>• Tracks file changes via SQLite AST hashes<br>• Expands change blast-radius for context<br>• Segments active modules & neighbors"]
        MIV["<b>Model Integrity Verifier (MIV)</b><br>• Verifies signed AI registries via cosign<br>• Guards against supply chain compromise<br>• Passes cryptographic validation status down"]
    end

    subgraph SHARED_ENGINE["Shared Graph Engine"]
        Joern["<b>Joern CPG Compiler</b><br>• Builds universal Code Property Graph<br>• Exposes call graph, CFG, PDG, taint paths<br>• Single bulk fetch per scan (GetCallGraph)"]
    end

    subgraph PA["Path A — Fast Rules"]
        PA_OH["<b>Tool Orchestrator</b><br>• Detects tech stack & languages<br>• Dispatches match-fit OSS scanners<br>  (OpenGrep, Gitleaks, linters)"]
        PA_LV["<b>LLM Verifier</b><br>• Filters orchestrator noise<br>  via local LLM constraint checks"]
        PA_OH --> PA_LV
    end

    subgraph PB["Path B — Semantic Analysis Funnel"]
        direction TB

        subgraph T1["Tier 1 — Surface Selection"]
            direction TB
            IBA["<b>Import Boundary Analyzer</b><br>• Walks source files (no Joern)<br>• Classifies files: Source / Sink / Auth<br>• ~40 stable package prefixes per language<br>• Framework-agnostic — custom wrappers<br>  still import canonical packages"]
            BFS["<b>Bidirectional BFS</b><br>• Forward BFS from source-boundary seeds<br>• Reverse BFS from sink-boundary seeds<br>• Intersection = source→sink surfaces<br>• canReachAuth BFS → IDOR candidates"]
            SOT["<b>Second-Order Detector</b><br>• Storage writes tagged as secondary sources<br>• Second BFS pass: DB read → output/exec<br>• Catches stored XSS, second-order SQLi,<br>  cross-request IDOR"]
            IBA --> BFS --> SOT
        end

        subgraph CA["Crypto Audit Pass (parallel)"]
            CAP["<b>Crypto API Auditor</b><br>• CPG query for known-bad crypto calls<br>• Checks: weak hash (MD5/SHA1 for passwords),<br>  bad cipher mode (AES-ECB, DES),<br>  predictable RNG, hardcoded keys<br>• No taint required — call node + arg analysis<br>• Maps directly to CWE-327/321/338/916"]
        end

        subgraph T2["Tier 2 — Structural Pre-Filter"]
            DCC["<b>Deterministic Contract Check</b><br>• Rulebook: CWE entries passing 3 filters —<br>  (1) Static decidability: invariant checkable from CPG<br>  (2) Sink-reachability: violation anchors to a Joern sink node<br>  (3) Exploitability frequency: cross-ref OWASP Top 10 + NVD CVE data<br>• Produces ~8–12 entries (CWE-89/78/22/79/94/918/862/327/502)<br>• CPG graph query — no ML, no LLM<br>• String concat on SQL taint path → certain violation<br>• canonicalize() before file sink → safe, drop<br>• Session attr equality before resource read → safe, drop<br>• Decidable safe → dropped<br>• Decidable violated → PoE direct (skip LLM)<br>• Inconclusive → Lightweight LLM"]
            LLMT2["<b>Lightweight LLM Triage</b><br>• Small local model (Qwen2.5-Coder-1.5B / DeepSeek-Coder-1.3B)<br>• Runs on CPU, inference in milliseconds<br>• Receives taint path as token sequence<br>• Closed question: any check between source and sink?<br>• No contract verification — coarse structural triage only<br>• Low suspicion → dropped<br>• High suspicion → LLM Tier 3"]
            DCC -->|"inconclusive"| LLMT2
        end

        subgraph T3["Tier 3 — LLM Semantic Reasoning"]
            direction TB
            SCL["<b>Security Contract Layer</b><br>• Static CWE → required invariant table<br>• SQL: parameterized query required<br>• Exec: no user input in arguments<br>• File: path canonicalized + allowlisted<br>• IDOR: session.owner == resource.owner<br>• Transforms open question into<br>  bounded contract verification"]
            CFP["<b>Control Flow Predicate Checker</b><br>• Enumerates CFG paths to each sink<br>• Verifies required preconditions hold<br>  on ALL paths, not just happy path<br>• Catches: auth on wrong branch,<br>  skippable state machine steps,<br>  post-hoc authorization"]
            AIP["<b>AI Code Failure Profile</b><br>• Biases LLM toward known AI agent<br>  failure modes:<br>  – Auth check on wrong session key<br>  – Sanitization applied to wrong variable<br>  – Error paths that skip invariants<br>  – Parameterization only on main path<br>• Addresses AI-generated code blind spot<br>  in traditional SAST tools"]
            LR["<b>LLM Reasoner</b><br>• Contract verification, not open judgment<br>• One bounded call per surface (no ASC)<br>• Input: surface + contract + CFG paths<br>  + AI failure profile bias<br>• Output: contract satisfied / violated +<br>  specific evidence line"]

            SCL --> CFP --> AIP --> LR
        end

        T1 --> T2
        LLMT2 -->|"high suspicion"| T3
        CA -.->|"crypto findings"| Dedup
    end

    %% Ingestion feeds
    Input --> DI & MIV
    DI --> PA_OH & Joern & IBA

    %% CPG feeds
    Joern -.->|"inter-procedural taint"| PA_OH
    Joern -.->|"call graph + CFG"| BFS
    Joern -.->|"call nodes + args"| CAP
    Joern -.->|"CPG subgraph per surface"| DCC
    Joern -.->|"CFG paths to sink"| CFP

    %% MIV streams
    MIV -.->|"signature status"| PA_LV


    %% Output fan-in
    PA_LV --> Dedup
    LR --> Dedup
    DCC -->|"decidable violated"| PoE_Engine

    Dedup["<b>Dedup & Report Generator</b><br>• Cascaded deduplication + SSVC alignment<br>• Merges taint, crypto, second-order findings<br>• Combines with budget/MIV alerts"]

    subgraph PoE["Proof-of-Exploit Layer"]
        PoE_Engine["<b>Automated Red-Team Agent</b><br>• Filters for confirmable flaw classes<br>• Executes sandboxed exploit simulations<br>• Generates verified impact traces<br>• Eliminates false positives empirically"]
    end

    Dedup -->|"BLOCK / HIGH targets"| PoE_Engine
    Dedup --> FinalReport
    PoE_Engine -->|"exploit verification status"| FinalReport

    FinalReport[/"<b>Interactive HTML Report</b><br>Contract violations + CFG evidence +<br>AI failure mode annotations +<br>Validated patch suggestions"/]

    %% Styles
    style INGEST fill:#eef2ff,stroke:#c7d2fe
    style SHARED_ENGINE fill:#faf5ff,stroke:#e9d5ff
    style PA fill:#f0f9ff,stroke:#bae6fd
    style PB fill:#ecfdf5,stroke:#a7f3d0
    style T1 fill:#fef9c3,stroke:#eab308
    style CA fill:#fdf4ff,stroke:#d946ef
    style T2 fill:#ffedd5,stroke:#f97316
    style T3 fill:#fee2e2,stroke:#ef4444
    style PoE fill:#fee2e2,stroke:#ef4444
