graph TD
    Input[/"Codebase Directory"/]

    subgraph INGEST["Ingestion"]
        Ingestion["Ingestion — hashes all changed files since the last scan via SQLite content-hash diffing, expands the file set with one-hop Code Property Graph neighbors for context, and verifies AI model signatures against a cosign-signed registry before gating LLM calls"]
    end

    subgraph PA["Path A — Pattern Detection"]
        PA_PS["Pattern Scanner — runs OpenGrep and ast-grep structural rules to detect cheat patterns and AI agent instruction file injections across the entire file set"]
        PA_TA["Taint Analyzer — builds a universal Code Property Graph with Joern and traces taint flows from untrusted sources through sanitizers to security-sensitive sinks"]
        PA_LV["LLM Verifier — applies Chain of Density and Structured Chain of Thought reasoning with XGrammar-2 output enforcement to filter false positives from both Path A scanners"]
    end

    subgraph PB["Path B — Semantic Detection with a Three-Tier Cost Funnel"]
        subgraph T1["Tier 1 — Surface Selection"]
            PB_SS["Surface Selector — traverses the CPG to rank code surfaces by risk relevance, extracts call graphs, enriches findings with Trivy CVE matches from OSV NVD and GitHub Advisory, and applies BOLAZ zero-trust ID tracking while eliminating approximately 95 percent of files"]
        end

        subgraph T2["Tier 2 — Classifier Chain"]
            PB_CC["Classifier Chain — runs a local UniXcoder model on CPU to classify each surface as vulnerable or safe, builds a depth-3 call chain context around uncertain surfaces, and generates a single-pass structured summary covering taint flow auth guards and logic flaws"]
        end

        subgraph T3["Tier 3 — LLM Reasoning"]
            PB_LR["LLM Reasoner — selects which surfaces reach the LLM using a token budget controller with compression, runs a bounded ReAct loop with at most three reasoning steps, and accumulates inferences across surfaces in a security context store"]
        end
    end

    Input --> Ingestion
    Ingestion --> PA_PS
    Ingestion --> PA_TA
    Ingestion --> PB_SS
    PA_TA --> PA_LV
    PA_PS --> PA_LV
    PA_TA -.-> PB_SS
    PB_SS --> PB_CC
    PB_CC -->|"uncertain cases"| PB_LR

    PA_LV --> Dedup
    PB_CC -->|"high-confidence findings"| Dedup
    PB_LR --> Dedup

    Dedup["Dedup and Report Generator — merges findings from both paths, applies cascaded deduplication, computes an SSVC-derived severity score with a 15 percentage point cross-path confidence boost, and generates a self-contained HTML dashboard with unified-diff patches per finding"]
    Dedup --> FinalReport["HTML Report"]
