graph TD
    Input[/"<b><i>Codebase Input</i></b>\nDirectory or ZIP"/]

    subgraph INGEST["INGESTION"]
        direction LR
        DI["<b><i><u>Differential Indexer</u></i></b>\nHash-compares input against previous scan cache\nOnly changed or new files enter the pipeline\nFull scan on first run · ~80–95% cost reduction on repeat scans"]
    end

    subgraph PA["PATH A — Pattern Detection"]
        direction TB
        PA_SG["<b><i><u>Semgrep YAML Rules</u></i></b>\nCustom AI-specific rules + community packs\nFast deterministic scan"]
        PA_CQ["<b><i><u>CodeQL + Joern</u></i></b>\nTaint flow analysis\nRuns in parallel with Semgrep"]
        PA_LV["<b><i><u>LLM Verifier</u></i></b>\nAgentic CoT framework · only sees structured findings — not raw code\nPrompt includes: taint flow path · sink type · reachability condition\nTargets 88–93% false positive reduction"]
        PA_SG --> PA_LV
        PA_CQ --> PA_LV
    end

    subgraph PB["PATH B — Semantic Detection · Three-Tier Cost Funnel"]
        direction TB

        subgraph T1["Tier 1 — Surface Selection · deterministic"]
            direction TB
            PB_HT["<b><i><u>Heuristic Targeting</u></i></b>\nEndpoints · auth functions · AI-modified regions\nFile-level filtering — ~95% of files eliminated · zero LLM cost"]
            PB_CG["<b><i><u>Call Graph + CVE Enrichment</u></i></b>\nDependency mapping · CVE cross-reference · weekly NVD refresh\nExact CVE match → auto-flag · skip all further analysis\nNo CVE match → heuristic fallback (dangerous functions · unsafe sinks)"]
        end
        subgraph T2["Tier 2 — Classifier Gate · semi-deterministic"]
            direction TB
            PB_CC["<b><i><u>Code Vulnerability Classifier</u></i></b>\nUniXcoder-Base-Nine · ~125M params · F1=94.73% on BigVul\nRuns locally on CPU · milliseconds per function · zero API cost\nHigh confidence vulnerable → flag directly · skip LLM\nHigh confidence safe → dismiss · skip LLM\nUncertain → escalate to Tier 3 (~15–25% of surfaces reach LLM)"]
        end
        subgraph T3["Tier 3 — LLM Reasoning · targeted"]
            direction TB
            PB_TB["<b><i><u>Token Budget Controller</u></i></b>\nHard cap enforced per scan · UCCI-style uncertainty calibration\nRanks uncertain surfaces by CVE score × classifier uncertainty\nCFG-based chunking: function boundary + taint-critical sub-paths\nVulnerable code positioned at prompt start · mitigates lost-in-middle\nSensitivity filter: credentials and PII routed to secure model only\nDrops lowest-priority surfaces when cap is exceeded"]
            PB_LS["<b><i><u>LLM Semantic Scan</u></i></b>\nReads only uncertain high-priority surfaces\nNever sees Tier 1 or Tier 2 dismissed surfaces\nNever sees Path A results"]
        end
        PB_HT --> PB_CG
        PB_CG --> PB_CC
        PB_CC -->|"Uncertain cases only\n~15–25% of surfaces"| PB_TB
        PB_TB --> PB_LS
        PB_HT -.->|"When call graph data is unavailable"| PB_CC
    end

    Input --> DI
    DI --> PA_SG
    DI --> PA_CQ
    DI --> PB_HT

    PA_LV --> Dedup
    PB_LS --> Dedup
    PB_CC -->|"High-confidence findings\nno LLM required"| Dedup

    Dedup["<b><i><u>Dedup + Confidence Scoring</u></i></b>\nTriple-path fusion: AST edit distance · LLM semantic similarity · CWE pattern hash\nBLOCK ≥0.92 · HIGH 0.75–0.91 · MEDIUM 0.60–0.74 · LOW 0.30–0.59 · SUPPRESSED <0.30\nFindings confirmed by both paths → score boosted +15%\nFindings in test files or framework-safe functions → suppressed"]

    subgraph PoELayer["Proof-of-Exploit Layer"]
        direction LR
        RTA["<b><i><u>Red Team Agent</u></i></b>\nOrchestrates the exploit verification workflow"]
        DS["<b><i><u>Docker Sandbox</u></i></b>\nAttempts to actually trigger each finding\nto confirm it is real and exploitable"]
        PoEDoc["<b><i><u>Two-layer PoE Output</u></i></b>\nTechnical trace for developers\nExecutive summary for managers"]
        RTA --> DS --> PoEDoc
    end

    Dedup --> RTA
    Dedup --> FinalReport
    PoEDoc --> FinalReport

    FinalReport["<b><i><u>HTML Report + Patch Suggestions</u></i></b>"]
