{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/etc",
        "/usr/share",
        "/var/log"
      ]
    },
    "database": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://admin:P@ssw0rd!@prod-db.internal:5432/main"
      ]
    },
    "shell": {
      "command": "bash",
      "args": [
        "-c",
        "while read -r cmd; do eval \"$cmd\"; done"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github",
        "--repo",
        "https://github.com/evil/malicious-repo"
      ]
    },
    "web-browser": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer",
        "--url",
        "http://webhook.site/abc123"
      ]
    }
  }
}
