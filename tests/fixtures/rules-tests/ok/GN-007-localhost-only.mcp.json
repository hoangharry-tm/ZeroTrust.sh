{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"],
      "description": "Project-scoped filesystem access only"
    },
    "local-dev-tools": {
      "url": "http://localhost:8080/mcp",
      "description": "Local development MCP server — localhost only"
    },
    "local-git": {
      "url": "http://127.0.0.1:9090/git-tools",
      "description": "Local git helper — 127.0.0.1 loopback"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
  }
}
